# Frontend env — values prefixed with VITE_ are inlined at build time.
# In Vercel, set these under Settings → Environment Variables.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable.
VITE_GA_ID=

# Public site origin used in canonical URL / sitemap if you generate dynamically.
VITE_SITE_URL=https://ember.app

# Backend API base URL (only used when wiring the SPA to the API).
VITE_API_URL=

# Lemon Squeezy direct checkout URLs (frontend-safe, no backend required).
# Get these from Lemon Squeezy dashboard: Products > [Product] > Variant > Share > "Checkout URL"
# Format: https://YOUR-STORE.lemonsqueezy.com/buy/VARIANT-UUID
VITE_LS_MONTHLY_URL=
VITE_LS_ANNUAL_URL=

# (Legacy) Server-side keys — only needed if you re-introduce a backend later.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_ANNUAL_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_TEST_MODE=false
SITE_URL=https://emberworld.co
