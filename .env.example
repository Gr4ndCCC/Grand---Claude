# Frontend env — values prefixed with VITE_ are inlined at build time.
# In Vercel, set these under Settings → Environment Variables.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable.
VITE_GA_ID=

# Public site origin used in canonical URL / sitemap if you generate dynamically.
VITE_SITE_URL=https://ember.app

# Backend API base URL (only used when wiring the SPA to the API).
VITE_API_URL=

# Supabase (database + auth). These are PUBLIC, browser-safe values — Row-Level
# Security protects the data. Defaults are baked into src/lib/supabase.ts, so
# these are only needed if you point the build at a different Supabase project.
VITE_SUPABASE_URL=https://ppyhzowtahctxoiehzgq.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_8WQ_98FiNPwycjYw-Gi5bA_FQ5H4Xsk

# ── Lemon Squeezy (Vault checkout — Merchant of Record) ──────────────────────
# Lemon Squeezy collects payment, handles all VAT/tax, and pays Ember out, so no
# registered business is required. The checkout opens as an on-page overlay
# (src/pages/VaultCheckout.tsx + lemon.js in index.html). The live checkout URLs
# live in src/config/checkout.ts.
#
# REQUIRED — the webhook is the source of truth for membership.
# app.lemonsqueezy.com → Settings → Webhooks → signing secret.
LEMONSQUEEZY_WEBHOOK_SECRET=

# OPTIONAL — only needed if you use the dynamic /api/lemonsqueezy/create-checkout
# endpoint instead of the static URLs in src/config/checkout.ts.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_MONTHLY_VARIANT_ID=1608126
LEMONSQUEEZY_ANNUAL_VARIANT_ID=1608155
LEMONSQUEEZY_TEST_MODE=false

# Lets the webhook unlock the Vault (profiles.sub_active) after a verified
# payment. Supabase → Settings → API → service_role key (SECRET, server-only).
SUPABASE_URL=https://ppyhzowtahctxoiehzgq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

SITE_URL=https://emberworld.co

# Resend email delivery
RESEND_API_KEY=
EMAIL_FROM=Ember <hello@emberworld.co>
EMAIL_REPLY_TO=support@emberworld.co
EMAIL_ADMIN_TO=support@emberworld.co
RESEND_NEWSLETTER_AUDIENCE_ID=
