# ── Deepgram (Speech-to-Text) ──────────────────────────────────────────────
# Get your key at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── Anthropic / Claude (LLM) ───────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── ElevenLabs (Text-to-Speech) ────────────────────────────────────────────
# Get your key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID from your ElevenLabs account (or use a pre-made voice)
# Example (Rachel): 21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
