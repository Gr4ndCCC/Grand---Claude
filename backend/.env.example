# Ember API — environment variables
# Copy to .env and fill in real values. Do NOT commit .env.

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/publishable key (safe for client use).
# Supabase now calls this SUPABASE_PUBLISHABLE_KEY — both names are supported.
SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Supabase service role / secret key (NEVER expose publicly).
# Supabase now calls this SUPABASE_SECRET_KEY — both names are supported.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# SUPABASE_SECRET_KEY=your-secret-key-here

# JWT secret used by Supabase (Project Settings > API)
JWT_SECRET=your-jwt-secret-here

# Stripe — live keys begin with sk_live_, test keys with sk_test_
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_VAULT_MONTHLY_PRICE_ID=price_your_monthly_price_id
STRIPE_VAULT_ANNUAL_PRICE_ID=price_your_annual_price_id

# Server
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed origins for CORS + Socket.io.
# In production, set this to your real frontend URL(s) — never leave it as *.
CORS_ORIGIN=http://localhost:5173
